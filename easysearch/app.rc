#include <winres.h>
#include "resource.h"


IDI_APPICON ICON "title.ico"

// Leaflet 1.9.4 embedded as binary resources (avoids CDN dependency)
IDR_LEAFLET_CSS RCDATA "leaflet.min.css"
IDR_LEAFLET_JS  RCDATA "leaflet.min.js"
IDD_MAINDIALOG DIALOGEX 0, 0, 1180, 700
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX | WS_MAXIMIZEBOX | WS_THICKFRAME
CAPTION "Easysearch - Nearby Search"
FONT 9, "Microsoft JhengHei UI", 400, 0, 0x1
BEGIN
        // ── Area-name mode controls (primary, shown by default) ──────────────
        LTEXT           "Area:",            IDC_AREA_STATIC,         10,  12,  26,   8
        EDITTEXT                            IDC_AREA_NAME,           38,  10, 294,  14, ES_AUTOHSCROLL
        PUSHBUTTON      "Search by Area",   IDC_BTN_SEARCH_AREA_NAME,540,  10, 136,  14

        // ── Lat/Lon mode controls (secondary, hidden by default) ─────────────
        LTEXT           "Lat:",             IDC_LAT_STATIC,          10,  12,  18,   8
        EDITTEXT                            IDC_LAT,                 30,  10,  80,  14, ES_AUTOHSCROLL
        LTEXT           "Lon:",             IDC_LON_STATIC,         120,  12,  18,   8
        EDITTEXT                            IDC_LON,                140,  10,  90,  14, ES_AUTOHSCROLL
        LTEXT           "Radius:",          IDC_RADIUS_STATIC,      240,  12,  28,   8
        EDITTEXT                            IDC_RADIUS,             272,  10,  55,  14, ES_AUTOHSCROLL
        PUSHBUTTON      "Search Center",    IDC_BTN_SEARCH,         540,  10,  72,  14
        PUSHBUTTON      "Search Area",      IDC_BTN_AREA,           618,  10,  60,  14

        // ── Always-visible controls ──────────────────────────────────────────
        LTEXT           "Preset:",          IDC_STATIC,             338,  12,  26,   8
        COMBOBOX                            IDC_TYPE_COMBO,         368,  10, 160, 300, CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
        PUSHBUTTON      "[ Lat/Lon ]",      IDC_BTN_TOGGLE_MODE,    684,  10,  70,  14
        PUSHBUTTON      "Settings",         IDC_BTN_SETTINGS,       760,  10,  60,  14

        CONTROL         "", IDC_MAPHOST, "STATIC", WS_BORDER | WS_VISIBLE | WS_CHILD, 10, 34, 760, 646
        EDITTEXT        IDC_DEBUG, 780, 34, 390, 646, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL | ES_READONLY | WS_BORDER
END
